<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" style="-fx-background-color: #121212;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.itc.healthtrack.controllers.RecommendationsController">
    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/></padding>

    <Label text="Análisis y Recomendaciones Inteligentes" textFill="WHITE">
        <font><Font name="System Bold" size="24.0"/></font>
    </Label>

    <HBox spacing="20.0" VBox.vgrow="ALWAYS">
        <VBox spacing="15.0" prefWidth="350.0" styleClass="panel-secundario" style="-fx-padding: 20;">
            <Label text="Selección de Paciente" textFill="WHITE">
                <font><Font name="System Bold" size="16.0"/></font>
            </Label>

            <ComboBox fx:id="comboPatients" maxWidth="Infinity" minHeight="-Infinity" prefHeight="35.0" promptText="Selecciona para analizar..." />
            <Button text="Generar Análisis Clínico" onAction="#onAnalyzePatient" styleClass="btn-primary" maxWidth="Infinity" minHeight="-Infinity" prefHeight="40.0"/>

            <Separator style="-fx-background-color: #444444;" />

            <Label text="Integración Web Service (FDA API)" textFill="WHITE">
                <font><Font name="System Bold" size="14.0"/></font>
            </Label>
            <TextArea fx:id="txtWebService" editable="false" wrapText="true" VBox.vgrow="ALWAYS" style="-fx-font-family: monospace; -fx-control-inner-background: #2c2c2c; -fx-text-fill: #e0e0e0;"/>
        </VBox>

        <VBox spacing="15.0" HBox.hgrow="ALWAYS" styleClass="panel-secundario" style="-fx-padding: 20;">
            <Label text="Diagnóstico y Alertas" textFill="WHITE">
                <font><Font name="System Bold" size="18.0"/></font>
            </Label>
            <TextArea fx:id="txtRecommendations" editable="false" wrapText="true" VBox.vgrow="ALWAYS" style="-fx-font-size: 14px; -fx-text-fill: #e0e0e0; -fx-control-inner-background: #2c2c2c;" />
        </VBox>
    </HBox>
</VBox>