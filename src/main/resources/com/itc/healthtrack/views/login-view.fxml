<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
    Nuevo layout horizontal de pantalla completa:
      [ Panel izquierdo — decorativo, fill ]  |  [ Panel derecho — formulario, 420px ]

    El panel derecho alterna internamente entre:
      · patientForm  (visible por defecto)
      · doctorPanel  (reemplaza al anterior al hacer clic en "¿Eres médico?")
-->
<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.itc.healthtrack.controllers.LoginController">

    <!-- ════════════════════════════════════════════════════════
         PANEL IZQUIERDO — decorativo (se expande para llenar)
         ════════════════════════════════════════════════════════ -->
    <VBox alignment="CENTER" spacing="28.0" HBox.hgrow="ALWAYS"
          style="-fx-background-color: #0b3160;
                 -fx-padding: 60 64 60 64;">

        <StackPane alignment="CENTER" prefWidth="150.0" prefHeight="150.0">
            <FontIcon iconColor="#1976d2" iconLiteral="fas-heartbeat" iconSize="150"/>
        </StackPane>

        <VBox alignment="CENTER" spacing="8.0">
            <Label text="HealthTrack Comunity" textFill="WHITE"
                   style="-fx-font-size: 36px; -fx-font-weight: bold;"/>
            <Label text="Clínica OwO" textFill="#42a5f5"
                   style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
            <Label text="Tu salud, nuestra prioridad" textFill="#1a3a5c"
                   style="-fx-font-size: 12px;"/>
        </VBox>
        <!-- Línea decorativa centrada -->
        <Region prefWidth="72.0" prefHeight="1.5"
                style="-fx-background-color: rgba(33,150,243,0.28);"/>

        <!-- Módulos destacados -->
        <HBox alignment="CENTER" spacing="36.0">

            <VBox alignment="CENTER" spacing="9.0">
                <VBox alignment="CENTER" prefWidth="62.0" prefHeight="62.0">
                    <FontIcon iconColor="#1565c0" iconLiteral="fas-user-md" iconSize="25"/>
                </VBox>
                <Label text="Médicos" textFill="#163552"
                       style="-fx-font-size: 11px;"/>
            </VBox>

            <VBox alignment="CENTER" spacing="9.0">
                <VBox alignment="CENTER" prefWidth="62.0" prefHeight="62.0">
                    <FontIcon iconColor="#1565c0" iconLiteral="fas-user" iconSize="25"/>
                </VBox>
                <Label text="Pacientes" textFill="#163552"
                       style="-fx-font-size: 11px;"/>
            </VBox>

            <VBox alignment="CENTER" spacing="9.0">
                <VBox alignment="CENTER" prefWidth="62.0" prefHeight="62.0">
                    <FontIcon iconColor="#1565c0" iconLiteral="fas-notes-medical" iconSize="25"/>
                </VBox>
                <Label text="Historiales" textFill="#163552"
                       style="-fx-font-size: 11px;"/>
            </VBox>

        </HBox>

    </VBox>

    <!-- ════════════════════════════════════════════════════════
         PANEL DERECHO — formulario (ancho fijo)
         Contiene patientForm y doctorPanel como hermanos;
         solo uno está managed+visible a la vez.
         ════════════════════════════════════════════════════════ -->
    <VBox prefWidth="420.0"
          style="-fx-background-color: #161616;
                 -fx-padding: 48 44 36 44;">

        <!-- ── Formulario PACIENTE (visible por defecto) ── -->
        <VBox fx:id="patientForm" alignment="CENTER" spacing="20.0" VBox.vgrow="ALWAYS">

            <VBox alignment="CENTER" spacing="4.0">
                <Label text="Bienvenido" textFill="WHITE"
                       style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                <Label text="Inicia sesión para continuar" textFill="#484848"
                       style="-fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="14.0" maxWidth="Infinity">

                <VBox spacing="5.0">
                    <Label text="CORREO ELECTRÓNICO" textFill="#555555"
                           style="-fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <TextField fx:id="emailField"
                               prefHeight="42.0" maxWidth="Infinity"
                               promptText="usuario@correo.com"
                               style="-fx-font-size: 14px;"/>
                </VBox>

                <VBox spacing="5.0">
                    <Label text="CONTRASEÑA" textFill="#555555"
                           style="-fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <PasswordField fx:id="passwordField"
                                   prefHeight="42.0" maxWidth="Infinity"
                                   promptText="••••••••"
                                   style="-fx-font-size: 14px;"/>
                </VBox>

                <Button fx:id="loginButton"
                        maxWidth="Infinity" prefHeight="46.0"
                        onAction="#onLoginButtonClick"
                        styleClass="btn-primary" text="Iniciar Sesión" textFill="WHITE"
                        style="-fx-font-size: 14px; -fx-font-weight: bold;">
                    <graphic>
                        <FontIcon iconColor="white" iconLiteral="fas-sign-in-alt" iconSize="15"/>
                    </graphic>
                </Button>

            </VBox>

            <!-- Footer del formulario paciente -->
            <VBox alignment="CENTER" spacing="10.0" >
                <Button fx:id="btnToggleDoctor"
                        mnemonicParsing="false" onAction="#onToggleDoctorPanel"
                        text="¿Eres médico? Acceder como doctor"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #555555;
                               -fx-font-size: 12px;
                               -fx-cursor: hand;
                               -fx-underline: true;
                               -fx-padding: 0;"/>
                <HBox alignment="CENTER" spacing="6.0">
                    <Label text="¿No tienes cuenta?" textFill="#444444"
                           style="-fx-font-size: 12px;"/>
                    <Button mnemonicParsing="false" onAction="#onGoToRegister"
                            styleClass="btn-default" text="Crear Cuenta"
                            style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>

        </VBox>

        <!-- ── Formulario DOCTOR (oculto por defecto, reemplaza al anterior) ── -->
        <VBox fx:id="doctorPanel" alignment="CENTER" spacing="20.0" VBox.vgrow="ALWAYS"
              visible="false" managed="false"
              style="-fx-background-color: #161616;">

            <VBox alignment="CENTER" spacing="8.0">
                <FontIcon iconColor="#4fc3f7" iconLiteral="fas-user-md" iconSize="40"/>
                <Label text="Acceso Médico" textFill="#4fc3f7"
                       style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                <Label text="Ingresa tus credenciales y código de acceso" textFill="#2a4a6a"
                       style="-fx-font-size: 12px;"/>
            </VBox>

            <VBox spacing="14.0" maxWidth="Infinity">

                <VBox spacing="5.0">
                    <Label text="CORREO DEL MÉDICO" textFill="#2a4a6a"
                           style="-fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <TextField fx:id="doctorEmailField"
                               prefHeight="42.0" maxWidth="Infinity"
                               promptText="doctor@clinica.com"
                               style="-fx-font-size: 14px;
                                      -fx-background-color: #0a1520;
                                      -fx-text-fill: #e0e0e0;
                                      -fx-prompt-text-fill: #2a4060;
                                      -fx-border-color: #1e3a5f;
                                      -fx-border-radius: 4;
                                      -fx-background-radius: 4;"/>
                </VBox>

                <VBox spacing="5.0">
                    <Label text="CONTRASEÑA" textFill="#2a4a6a"
                           style="-fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <PasswordField fx:id="doctorPasswordField"
                                   prefHeight="42.0" maxWidth="Infinity"
                                   promptText="••••••••"
                                   style="-fx-font-size: 14px;
                                          -fx-background-color: #0a1520;
                                          -fx-text-fill: #e0e0e0;
                                          -fx-prompt-text-fill: #2a4060;
                                          -fx-border-color: #1e3a5f;
                                          -fx-border-radius: 4;
                                          -fx-background-radius: 4;"/>
                </VBox>

                <VBox spacing="5.0">
                    <Label text="CÓDIGO DE ACCESO" textFill="#2a4a6a"
                           style="-fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <TextField fx:id="doctorTokenField"
                               prefHeight="42.0" maxWidth="Infinity"
                               promptText="Proporcionado por administración"
                               style="-fx-font-size: 14px;
                                      -fx-background-color: #0a1520;
                                      -fx-text-fill: #e0e0e0;
                                      -fx-prompt-text-fill: #2a4060;
                                      -fx-border-color: #1e3a5f;
                                      -fx-border-radius: 4;
                                      -fx-background-radius: 4;"/>
                </VBox>

                <Button fx:id="doctorLoginButton"
                        maxWidth="Infinity" prefHeight="46.0"
                        mnemonicParsing="false" onAction="#onDoctorLoginButtonClick"
                        text="Entrar como Doctor"
                        style="-fx-background-color: #1565c0;
                               -fx-text-fill: white;
                               -fx-font-size: 14px;
                               -fx-font-weight: bold;
                               -fx-cursor: hand;
                               -fx-background-radius: 6;">
                    <graphic>
                        <FontIcon iconColor="white" iconLiteral="fas-stethoscope" iconSize="14"/>
                    </graphic>
                </Button>

            </VBox>

            <Button onAction="#onToggleDoctorPanel"
                    text="Volver al inicio de sesión"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #2a4a6a;
                           -fx-font-size: 12px;
                           -fx-cursor: hand;
                           -fx-underline: true;
                           -fx-padding: 0;"/>

        </VBox>

        <!-- Error compartido — visible debajo del formulario activo -->
        <Label fx:id="errorLabel" textFill="#ff5252" visible="false"
               wrapText="true" maxWidth="Infinity"
               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8 0 0 0;"/>

    </VBox>

</HBox>
